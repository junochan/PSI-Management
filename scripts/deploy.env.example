# 复制为 deploy.env 后按需修改（deploy.env 勿提交密钥）
#   cp scripts/deploy.env.example scripts/deploy.env

# ---------- 端口（可单独配置）----------
BACKEND_PORT=8080
FRONTEND_PORT=4173

# ---------- 路径 ----------
# 项目根目录（脚本会自动推断，一般无需设置）
# PROJECT_ROOT=/opt/PSI-Management

# 后端可执行 jar（默认指向 Maven 打包产物）
# BACKEND_JAR=/opt/PSI-Management/psi-manage-system-backend/target/psi-manage-system-backend-1.0.0.jar

# 前端静态资源目录（npm run build 产出）
# FRONTEND_DIR=/opt/PSI-Management/psi-manage-system-front

# ---------- JVM ----------
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
JAVA_OPTS="-Xms256m -Xmx1024m"

# ---------- Spring Boot / 运行期（与 application.yml 一致，按需取消注释）----------
# export SPRING_PROFILES_ACTIVE=prod
# export DB_USERNAME=root
# export DB_PASSWORD=your_password
# export JWT_SECRET=至少32字符的随机密钥
# export APP_ATTACHMENT_DIR=/var/lib/smart-ims/data
