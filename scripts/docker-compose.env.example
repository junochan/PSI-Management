# 复制为 docker-compose.env 后与 scripts/docker-compose-deploy.sh 或
#   docker compose --env-file docker-compose.env up -d
# 一起使用（docker-compose.env 勿提交真实密钥）

# ---------- 端口 ----------
BACKEND_PORT=8080
MYSQL_PORT=3306

# ---------- 数据与 JAR 挂载（相对仓库根目录，可改为绝对路径）----------
# 持久化：附件、向量缓存、应用日志
DATA_DIR=./deploy-data/data
# 宿主 Maven 打包输出目录（内含 psi-manage-system-backend-*.jar）
JAR_DIR=./psi-manage-system-backend/target

# 若 jar 文件名与默认不一致（见 pom.xml version）
# JAR_FILE=psi-manage-system-backend-1.0.0.jar

# ---------- MySQL（compose 内 mysql 服务）----------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smart_ims
# 后端连接 DB 的密码，需与 MYSQL_ROOT_PASSWORD 一致（或改为独立 DB 用户后在库内授权）
DB_USERNAME=root
DB_PASSWORD=root

# ---------- Spring ----------
SPRING_PROFILES_ACTIVE=prod
# JWT_SECRET=至少32字符的生产随机串

# ---------- 可选 ----------
# JVM
# JAVA_OPTS=-Xms256m -Xmx1024m
# 使用宿主机或其它机器的 MySQL 时：可删掉 compose 中 mysql 服务并设置 DB_HOST（需自行调整 depends_on）
# DB_HOST=mysql
